{
  "name": "meet-juan",
  "version": "0.1.4",
  "description": "Meet Juan Acosta — an interactive CLI portfolio built with TypeScript.",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "meet-juan": "dist/index.js"
  },
  "files": [
    "dist"
  ],
  "keywords": [
    "portfolio",
    "cli",
    "developer",
    "interactive",
    "terminal",
    "juan-acosta",
    "meet-juan"
  ],
  "author": "Juan Acosta <acosta.juan@icloud.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/acostajs/cli-portfolio.git"
  },
  "homepage": "https://github.com/acostajs/cli-portfolio#readme",
  "bugs": {
    "url": "https://github.com/acostajs/cli-portfolio/issues"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "type-check": "tsc --noEmit",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "prepare": "husky install"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "chalk": "^5.3.0",
    "commander": "^11.1.0",
    "enquirer": "^2.4.1",
    "figlet": "^1.11.0"
  },
  "devDependencies": {
    "@types/figlet": "^1.7.0",
    "@types/node": "^25.6.0",
    "@typescript-eslint/eslint-plugin": "^8.59.0",
    "@typescript-eslint/parser": "^8.59.0",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^9.1.2",
    "eslint-plugin-prettier": "^5.5.5",
    "husky": "^8.0.3",
    "lint-staged": "^15.5.2",
    "prettier": "^3.8.3",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.0"
  }
}
